{
    "name": "auth-services",
    "version": "1.0.0",
    "description": "authentication service for user management",
    "main": "server.js",
    "scripts": {
        "dev": "nodemon ./src/server.ts",
        "formate:check": "prettier . --check",
        "formate:fix": "prettier . --write",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/robinmahto/auth-services.git"
    },
    "keywords": [
        "node.js",
        "express.js",
        "TypeScript"
    ],
    "author": "Robin Mahto <robinmahto1999@gmail.com>",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/robinmahto/auth-services/issues"
    },
    "homepage": "https://github.com/robinmahto/auth-services#readme",
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.11.19",
        "@types/winston": "^2.4.4",
        "@typescript-eslint/eslint-plugin": "^7.0.1",
        "@typescript-eslint/parser": "^7.0.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "husky": "^9.0.11",
        "lint-staged": "^15.2.2",
        "nodemon": "^3.0.3",
        "prettier": "3.2.5",
        "typescript": "^5.3.3",
        "typescript-eslint": "^7.0.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run formate:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "winston": "^3.11.0"
    }
}
