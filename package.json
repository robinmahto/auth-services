{
    "name": "auth-services",
    "version": "1.0.0",
    "description": "authentication service for user management",
    "main": "./src/server.ts",
    "scripts": {
        "dev": "cross-env NODE_ENV=dev nodemon ./src/server.ts",
        "formate:check": "prettier . --check",
        "formate:fix": "prettier . --write",
        "lint:check": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepare": "husky",
        "test": "jest --watch --runInBand",
        "start": "ts-node src/index.ts",
        "typeorm": "typeorm-ts-node-commonjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/robinmahto/auth-services.git"
    },
    "keywords": [
        "node.js",
        "express.js",
        "TypeScript"
    ],
    "author": "Robin Mahto <robinmahto1999@gmail.com>",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/robinmahto/auth-services/issues"
    },
    "homepage": "https://github.com/robinmahto/auth-services#readme",
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/express": "^4.17.21",
        "@types/express-validator": "^3.0.0",
        "@types/jest": "^29.5.12",
        "@types/node": "^16.11.10",
        "@types/supertest": "^6.0.2",
        "@types/winston": "^2.4.4",
        "@typescript-eslint/eslint-plugin": "^7.0.1",
        "@typescript-eslint/parser": "^7.0.1",
        "cross-env": "^7.0.3",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "husky": "^9.0.11",
        "jest": "^29.7.0",
        "lint-staged": "^15.2.2",
        "nodemon": "^3.0.3",
        "prettier": "3.2.5",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node": "10.9.1",
        "typescript": "4.5.2",
        "typescript-eslint": "^7.0.1"
    },
    "lint-staged": {
        "*.ts": [
            "npm run formate:fix",
            "npm run lint:fix"
        ]
    },
    "dependencies": {
        "@types/http-errors": "^2.0.4",
        "bcrypt": "^5.1.1",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-validator": "^7.0.1",
        "http-errors": "^2.0.0",
        "pg": "^8.4.0",
        "reflect-metadata": "^0.1.13",
        "typeorm": "0.3.20",
        "winston": "^3.11.0"
    }
}
